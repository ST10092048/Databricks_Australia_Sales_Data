    {
      "name": "c07905f9",
      "displayName": "Sales Trend by Month",
      "queryLines": [
        "SELECT\n",
        "  d.month_name,\n",
        "  SUM(o.order_amt) AS total_sales\n",
        "FROM\n",
        "  salesdata.gold.orders_fact o\n",
        "    JOIN salesdata.gold.dim_date d\n",
        "      ON o.date_key = d.date_key\n",
        "GROUP BY\n",
        "  d.month_name\n",
        "ORDER BY\n",
        "  d.month_name"
      ],
      "catalog": "salesdata",
      "schema": "gold"
    },
    {
      "name": "b5bbfc07",
      "displayName": "orders_fact",
      "queryLines": [
        "SELECT * FROM salesdata.gold.orders_fact\r\n",
        "\r\n"
      ]
    },
    {
      "name": "c46d09ab",
      "displayName": "Order Amount by State",
      "queryLines": [
        "SELECT\r\n",
        "  c.state,\r\n",
        "  SUM(o.order_amt) AS total_revenue\r\n",
        "FROM\r\n",
        "  salesdata.gold.orders_fact o\r\n",
        "    JOIN salesdata.gold.dim_customer c\r\n",
        "      ON o.customer_id = c.customer_id\r\n",
        "GROUP BY\r\n",
        "  c.state;"
      ],
      "catalog": "salesdata",
      "schema": "gold"
    },
    {
      "name": "998f46f5",
      "displayName": "Sales Rep Performance",
      "queryLines": [
        "\r\n",
        "\r\n",
        "SELECT s.salesrep,SUM(o.order_amt) AS TopSales FROM orders_fact o \r\n",
        "JOIN dim_sales_rep s on o.sales_rep_key = s.sales_rep_key\r\n",
        "GROUP BY s.salesrep"
      ],
      "catalog": "salesdata",
      "schema": "gold"
    },
    {
      "name": "27a8f12a",
      "displayName": "Sales Pipeline Funnel",
      "queryLines": [
        "\r\n",
        "SELECT status,COUNT(opportunity_id) as opps FROM opportunities_fact GROUP BY status"
      ],
      "catalog": "salesdata",
      "schema": "gold"
    },
    {
      "name": "55b395fb",
      "displayName": "Top Customers",
      "queryLines": [
        "select c.customer_name,ROUND(SUM(o.order_amt),2) as Top_Customer from orders_fact o JOIN\r\n",
        "dim_customer c on c.customer_id = o.customer_id GROUP BY c.customer_name \r\n",
        "ORDER BY SUM(o.order_amt) DESC LIMIT 5"
      ],
      "catalog": "salesdata",
      "schema": "gold"
    },
    {
      "name": "f5bf305f",
      "displayName": "Executive KPI Cards",
      "queryLines": [
        "SELECT\r\n",
        "(SELECT ROUND(SUM(order_amt),2) FROM orders_fact) AS Total_Revenue,\r\n",
        "\r\n",
        "(SELECT COUNT(order_id) FROM orders_fact) AS Total_Orders,\r\n",
        "\r\n",
        "(SELECT ROUND(AVG(order_amt),2) FROM orders_fact) AS Average_Deal_Size,\r\n",
        "\r\n",
        "(SELECT SUM(amount) FROM opportunities_fact) AS Pipeline_Value;"
      ],
      "catalog": "salesdata",
      "schema": "gold"
    }
  ],
